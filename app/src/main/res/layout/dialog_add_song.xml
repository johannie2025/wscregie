<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="wrap_content"
    android:orientation="vertical" android:padding="16dp" android:background="#0F1219">
    <EditText android:id="@+id/et_song_title"
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:hint="Titre du chant *" android:textColor="#E2E8F0" android:textColorHint="#64748B"
        android:background="#1E2535" android:padding="10dp" android:layout_marginBottom="8dp"/>
    <EditText android:id="@+id/et_song_author"
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:hint="Auteur / Artiste" android:textColor="#E2E8F0" android:textColorHint="#64748B"
        android:background="#1E2535" android:padding="10dp" android:layout_marginBottom="8dp"/>
    <Spinner android:id="@+id/sp_song_lang"
        android:layout_width="match_parent" android:layout_height="40dp"
        android:entries="@array/languages" android:background="#1E2535"
        android:layout_marginBottom="8dp"/>
    <EditText android:id="@+id/et_song_bg"
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:hint="URL image de fond (optionnel)" android:textColor="#E2E8F0" android:textColorHint="#64748B"
        android:background="#1E2535" android:padding="10dp" android:layout_marginBottom="8dp"/>
    <EditText android:id="@+id/et_song_lyrics"
        android:layout_width="match_parent" android:layout_height="150dp"
        android:hint="Paroles (strophes séparées par ligne vide)&#10;&#10;Strophe 1&#10;Au nom de Jésus…&#10;&#10;Refrain&#10;Gloire à Dieu…"
        android:textColor="#E2E8F0" android:textColorHint="#64748B"
        android:background="#1E2535" android:padding="10dp"
        android:gravity="top" android:inputType="textMultiLine"/>
</LinearLayout>
