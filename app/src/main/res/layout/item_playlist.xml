<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="wrap_content"
    android:orientation="horizontal" android:padding="7dp" android:gravity="center_vertical"
    android:background="@drawable/bg_card" android:layout_marginBottom="2dp"
    android:layout_marginStart="4dp" android:layout_marginEnd="4dp">
    <TextView android:id="@+id/tv_pl_type"
        android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:textSize="14sp" android:layout_marginEnd="8dp"/>
    <TextView android:id="@+id/tv_pl_label"
        android:layout_width="0dp" android:layout_height="wrap_content"
        android:layout_weight="1" android:textSize="12sp" android:textColor="#E2E8F0"
        android:singleLine="true" android:ellipsize="end"/>
    <Button android:id="@+id/btn_pl_item_project"
        android:layout_width="28dp" android:layout_height="28dp"
        android:text="▶" android:textSize="11sp" android:padding="0dp"
        android:background="@drawable/bg_btn_icon" android:textColor="#F0C040"/>
</LinearLayout>
