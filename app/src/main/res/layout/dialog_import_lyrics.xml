<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="wrap_content"
    android:orientation="vertical" android:padding="16dp" android:background="#0F1219">
    <EditText android:id="@+id/et_import_title"
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:hint="Titre du chant" android:textColor="#E2E8F0" android:textColorHint="#64748B"
        android:background="#1E2535" android:padding="10dp" android:layout_marginBottom="8dp"/>
    <EditText android:id="@+id/et_import_lyrics"
        android:layout_width="match_parent" android:layout_height="160dp"
        android:hint="Collez les paroles ici…" android:textColor="#E2E8F0" android:textColorHint="#64748B"
        android:background="#1E2535" android:padding="10dp"
        android:gravity="top" android:inputType="textMultiLine"/>
</LinearLayout>
