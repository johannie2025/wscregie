<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="wrap_content"
    android:orientation="vertical" android:padding="16dp" android:background="#0F1219">
    <EditText android:id="@+id/et_pl_name"
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:hint="Nom du culte / événement" android:textColor="#E2E8F0" android:textColorHint="#64748B"
        android:background="#1E2535" android:padding="10dp" android:layout_marginBottom="10dp"/>
    <Spinner android:id="@+id/sp_pl_type"
        android:layout_width="match_parent" android:layout_height="40dp"
        android:entries="@array/service_types" android:background="#1E2535"/>
</LinearLayout>
