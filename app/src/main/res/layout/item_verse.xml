<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="wrap_content"
    android:orientation="horizontal" android:padding="8dp" android:gravity="top">
    <TextView android:id="@+id/tv_verse_num"
        android:layout_width="24dp" android:layout_height="wrap_content"
        android:textSize="11sp" android:textColor="#F0C040" android:textStyle="bold"
        android:paddingTop="2dp"/>
    <TextView android:id="@+id/tv_verse_text"
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:textSize="13sp" android:textColor="#E2E8F0" android:lineSpacingMultiplier="1.5"/>
</LinearLayout>
