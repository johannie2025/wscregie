<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:background="#060810" android:orientation="vertical">
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="horizontal" android:padding="8dp" android:background="#0F1219">
        <EditText android:id="@+id/et_maestro_ip"
            android:layout_width="0dp" android:layout_height="34dp" android:layout_weight="1"
            android:hint="IP régie" android:textSize="12sp" android:textColor="#E2E8F0"
            android:textColorHint="#64748B" android:background="#1E2535" android:paddingStart="8dp" android:inputType="phone"/>
        <Button android:id="@+id/btn_maestro_connect"
            android:layout_width="wrap_content" android:layout_height="34dp"
            android:text="▶ Connect" android:textSize="11sp" android:background="#7C3AED"
            android:textColor="#FFFFFF" android:layout_marginStart="6dp" android:paddingStart="10dp" android:paddingEnd="10dp"/>
        <TextView android:id="@+id/tv_maestro_conn"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="○" android:textSize="10sp" android:textColor="#EF4444"
            android:layout_marginStart="8dp" android:gravity="center_vertical"/>
    </LinearLayout>
    <LinearLayout android:layout_width="match_parent" android:layout_height="0dp"
        android:layout_weight="1" android:orientation="vertical" android:gravity="center" android:padding="20dp">
        <TextView android:id="@+id/tv_maestro_label"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:textSize="14sp" android:textColor="#7C3AED" android:gravity="center"
            android:letterSpacing="0.08" android:layout_marginBottom="12dp"/>
        <TextView android:id="@+id/tv_maestro_lyric"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:textSize="28sp" android:textColor="#FFFFFF" android:gravity="center"
            android:lineSpacingMultiplier="1.5" android:textStyle="bold"/>
    </LinearLayout>
    <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
        android:padding="4dp" android:text="🎵 Maestro — Wise Smart Church System"
        android:textSize="9sp" android:textColor="#3D4459" android:gravity="center"/>
</LinearLayout>
