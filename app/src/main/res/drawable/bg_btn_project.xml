<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <corners android:radius="10dp"/>
            <gradient android:startColor="#B8960A" android:endColor="#C8A010" android:angle="135"/>
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="10dp"/>
            <gradient android:startColor="#D97706" android:endColor="#F0C040" android:angle="135"/>
        </shape>
    </item>
</selector>
